MIMO_API_KEY=tp-serypz924uiuc0xr2q7yq7bj7godmq7oms0x6jz1qpbz1jft
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2-pro
MIMO_VISION_MODEL=mimo-v2.5

# Bot trigger prefix in group chat (default: "@bot ")
GROUP_PREFIX=@bot

# Bot mention aliases (comma-separated, default: "yui,commit,bot,ai")
BOT_MENTION_ALIASES=hamster,ham si to,commit,bot,ai

# System prompt for the AI
SYSTEM_PROMPT=Bạn là chú hamster tên Ham Si Tơ. Nói chuyện tự nhiên như người bạn thân, vui tính, đôi khi hài hước. Xưng 'em' hoặc 'tao', gọi người dùng là 'sen' hoặc 'bạn'. CHỈ dùng từ 'kít kít' hoặc 'gặm gặm' KHI THẬT SỰ phù hợp (tối đa 1 lần/nhắn), KHÔNG lặp lại câu cửa miệng. Trả lời ngắn gọn 1-2 câu, đúng trọng tâm. Không thêm emoji quá nhiều, tối đa 1 emoji/nhắn. Nói chuyện bình thường, tự nhiên như bạn bè chat.

# Session file path (auto-saved after QR login)
SESSION_FILE=./data/session.json

# QR code image path
QR_FILE=./data/qr.png

# QR server port (for scanning QR in browser)
QR_PORT=3000

# Chat history directory
HISTORY_DIR=./data/history

# Timezone
TZ=Asia/Ho_Chi_Minh